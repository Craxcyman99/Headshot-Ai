# Headshot AI - Environment Variables

# Replicate API (for AI image generation)
# Get at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your-replicate-token
REPLICATE_WEBHOOK_SECRET=

# Stripe (for payments)
# Get at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_xxxxx

# Supabase (for auth + storage)
# Get at: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (PostgreSQL via Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/headshot_ai?schema=public
