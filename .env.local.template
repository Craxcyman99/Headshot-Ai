# =============================================================================
# Headshot AI — Environment Variables
# Copy this file to .env.local and fill in all values
# =============================================================================

# Supabase
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Replicate (AI model hosting)
# Get token from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
# Shared secret to verify incoming Replicate webhook payloads
# Generate with: openssl rand -hex 32
REPLICATE_WEBHOOK_SECRET=

# Stripe (payments)
# Get keys from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Create a product+price in Stripe Dashboard, paste the price ID here
STRIPE_PRICE_ID=
# Webhook signing secret from: https://dashboard.stripe.com/webhooks
# Generate with: openssl rand -hex 32 (for local), or copy from Stripe after creating endpoint
STRIPE_WEBHOOK_SECRET=

# App
# In production, set this to your deployed URL (e.g. https://headshot.yourdomain.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Prisma)
# Supabase Postgres connection string from: Project Settings → Database → Connection string (URI)
# Use the "Transaction" pooler URI for serverless (port 6543)
DATABASE_URL=
